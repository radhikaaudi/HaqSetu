{
  "id": "girl_child_scholarship",
  "name": { "en": "Girl Child Education Scholarship", "hi": "बालिका शिक्षा छात्रवृत्ति" },
  "authority": "State Department of Education",
  "note": "Representative demo rules for HaqSetu. Production must load the authority's official eligibility rules.",
  "benefit": { "type": "cash", "amount_inr_per_year": 12000 },
  "eligibility": [
    {
      "id": "has_girl_in_school",
      "fact": "children.girls",
      "op": "gte",
      "value": 1,
      "explain": { "en": "You have at least one daughter", "hi": "आपकी कम से कम एक बेटी है" }
    },
    {
      "id": "girl_enrolled",
      "fact": "children.in_school",
      "op": "gte",
      "value": 1,
      "explain": { "en": "At least one child is enrolled in school", "hi": "कम से कम एक बच्चा स्कूल में पढ़ रहा है" }
    },
    {
      "id": "income_below_limit",
      "fact": "annual_income_inr",
      "op": "lte",
      "value": 250000,
      "explain": { "en": "Your annual household income is below ₹2,50,000", "hi": "आपकी वार्षिक पारिवारिक आय ₹2,50,000 से कम है" }
    }
  ],
  "required_documents": [
    { "id": "aadhaar", "name": { "en": "Daughter's Aadhaar card", "hi": "बेटी का आधार कार्ड" } },
    { "id": "school_id", "name": { "en": "School enrollment / bonafide certificate", "hi": "स्कूल नामांकन / बोनाफाइड प्रमाण पत्र" } },
    { "id": "income_cert", "name": { "en": "Income certificate", "hi": "आय प्रमाण पत्र" } },
    { "id": "bank_passbook", "name": { "en": "Bank account passbook", "hi": "बैंक खाता पासबुक" } }
  ],
  "form": {
    "template": "forms/girl_child_scholarship.pdf",
    "fields": [
      { "pdf_field": "guardian_name", "from_fact": "full_name" },
      { "pdf_field": "annual_income", "from_fact": "annual_income_inr" },
      { "pdf_field": "district", "from_fact": "district" }
    ]
  },
  "submission": {
    "where": { "en": "The child's school office or the state education portal", "hi": "बच्चे का स्कूल कार्यालय या राज्य शिक्षा पोर्टल" },
    "deadline": null
  }
}
