# Which model provider the app uses at runtime: "openai" (GPT-5.6) or "gemini".
LLM_PROVIDER=openai

# --- OpenAI / GPT-5.6 ---
OPENAI_API_KEY=
# Optional: override the default GPT-5.6 Terra model tier.
OPENAI_MODEL=gpt-5.6-terra
# low, medium, or high
OPENAI_REASONING_EFFORT=medium

# --- Gemini (free alternative; get a key at https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
